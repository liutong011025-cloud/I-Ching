# Dify API（卦象 AI 解读）
# 从 Dify 应用「API 访问」中复制 API Key，支持云端 api.dify.ai 或自建 base
NEXT_PUBLIC_DIFY_API_KEY=app-xxxxxxxx
# 自建 Dify 时填写，例如 https://your-dify.com/v1
# NEXT_PUBLIC_DIFY_API_BASE=https://api.dify.ai/v1

# 火山引擎方舟 API（卦象意境图生成，仅服务端使用）
ARK_API_KEY=ark-xxxxxxxx
# ARK_API_BASE=https://ark.cn-beijing.volces.com/api/v3
# SEEDREAM_MODEL_ID=doubao-seedream-4-5-251128
